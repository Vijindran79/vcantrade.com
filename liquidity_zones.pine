//@version=6
indicator("[Vcani] Smart Money Liquidity Zones", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ============================================================
// Smart Money Concepts - Liquidity Zone Visualizer
// Auto-detects: Order Blocks, Fair Value Gaps, Liquidity Pools
// ============================================================

// --- INPUTS ---
groupLookback = "Zone Settings"
lookback      = input.int(100, "Lookback Candles", minval=20, maxval=500, group=groupLookback)
obStrength    = input.float(1.5, "OB Volume Multiplier", minval=1.0, maxval=5.0, step=0.1, group=groupLookback)
showOB        = input.bool(true, "Show Order Blocks", group=groupLookback)
showFVG       = input.bool(true, "Show Fair Value Gaps", group=groupLookback)
showPools     = input.bool(true, "Show Liquidity Pools", group=groupLookback)
showTrend     = input.bool(true, "Show Trend Lines", group=groupLookback)
showOTE       = input.bool(true, "Show OTE Levels", group=groupLookback)

// --- COLORS ---
cBullishOB      = color.new(color.teal, 70)
cBearishOB      = color.new(color.maroon, 70)
cBullishFVG     = color.new(color.green, 80)
cBearishFVG     = color.new(color.red, 80)
cEqHighs        = color.new(color.orange, 75)
cEqLows         = color.new(color.blue, 75)
cSupportLine    = color.new(color.teal, 30)
cResistanceLine = color.new(color.maroon, 30)
cOTE            = color.new(color.purple, 50)

// --- OTE LEVELS (global scope - plot cannot live inside functions) ---
recentHigh = ta.highest(high, 20)
recentLow  = ta.lowest(low, 20)
rangeSize  = recentHigh - recentLow
oteLong    = showOTE and rangeSize > 0 ? recentHigh - rangeSize * 0.62 : na
oteShort   = showOTE and rangeSize > 0 ? recentLow  + rangeSize * 0.62 : na
plot(oteLong,  "OTE Long",  color=cOTE, style=plot.style_linebr)
plot(oteShort, "OTE Short", color=cOTE, style=plot.style_linebr)

// ============================================================
// MAIN DRAWING - runs once on last bar to avoid duplicates
// ============================================================
if barstate.islast
    tolerance = close * 0.0015

    // --- ORDER BLOCKS (max 5 of each type, nearest first) ---
    if showOB
        int obBullCount = 0
        int obBearCount = 0
        avgVol = ta.sma(volume, 5)
        for i = 2 to lookback - 3
            // Bullish OB
            if obBullCount < 5 and close[i] < open[i]
                move1 = close[i+1] - open[i+1]
                move2 = close[i+2] - open[i+2]
                strongMove = (move1 > 0 or move2 > 0) and close[i+2] > close[i]
                highVol    = volume[i] > avgVol[i] * obStrength
                if strongMove and highVol
                    box.new(bar_index[i], high[i], bar_index, low[i],
                        border_color=color.new(color.teal, 0),
                        bgcolor=cBullishOB,
                        text="Bull OB",
                        text_color=color.white,
                        text_size=size.tiny)
                    obBullCount += 1
            // Bearish OB
            if obBearCount < 5 and close[i] > open[i]
                move1 = open[i+1] - close[i+1]
                move2 = open[i+2] - close[i+2]
                strongMove = (move1 > 0 or move2 > 0) and close[i+2] < close[i]
                highVol    = volume[i] > avgVol[i] * obStrength
                if strongMove and highVol
                    box.new(bar_index[i], high[i], bar_index, low[i],
                        border_color=color.new(color.maroon, 0),
                        bgcolor=cBearishOB,
                        text="Bear OB",
                        text_color=color.white,
                        text_size=size.tiny)
                    obBearCount += 1

    // --- FAIR VALUE GAPS (max 5 of each type) ---
    if showFVG
        int fvgBullCount = 0
        int fvgBearCount = 0
        for i = 1 to lookback - 2
            if fvgBullCount < 5 and low[i] > high[i-1]
                box.new(bar_index[i], low[i], bar_index, high[i-1],
                    border_color=color.new(color.green, 0),
                    bgcolor=cBullishFVG,
                    text="FVG+",
                    text_color=color.white,
                    text_size=size.tiny)
                fvgBullCount += 1
            if fvgBearCount < 5 and high[i] < low[i-1]
                box.new(bar_index[i], low[i-1], bar_index, high[i],
                    border_color=color.new(color.red, 0),
                    bgcolor=cBearishFVG,
                    text="FVG-",
                    text_color=color.white,
                    text_size=size.tiny)
                fvgBearCount += 1

    // --- LIQUIDITY POOLS (de-duplicated, max 5 each) ---
    if showPools
        float[] drawnHighs = array.new_float(0)
        float[] drawnLows  = array.new_float(0)
        int poolHighCount = 0
        int poolLowCount  = 0

        // Equal Highs - skip duplicates
        for i = 1 to lookback - 2
            if poolHighCount >= 5
                break
            for j = i + 2 to math.min(i + 12, lookback - 1)
                if math.abs(high[i] - high[j]) <= tolerance
                    mid = (high[i] + high[j]) / 2
                    bool alreadyDrawn = false
                    if array.size(drawnHighs) > 0
                        for k = 0 to array.size(drawnHighs) - 1
                            if math.abs(mid - array.get(drawnHighs, k)) <= tolerance
                                alreadyDrawn := true
                                break
                    if not alreadyDrawn
                        box.new(bar_index[j], mid + tolerance, bar_index, mid - tolerance,
                            border_color=color.new(color.orange, 0),
                            bgcolor=cEqHighs,
                            text="EqHighs",
                            text_color=color.white,
                            text_size=size.tiny)
                        array.push(drawnHighs, mid)
                        poolHighCount += 1
                    break

        // Equal Lows - skip duplicates
        for i = 1 to lookback - 2
            if poolLowCount >= 5
                break
            for j = i + 2 to math.min(i + 12, lookback - 1)
                if math.abs(low[i] - low[j]) <= tolerance
                    mid = (low[i] + low[j]) / 2
                    bool alreadyDrawn = false
                    if array.size(drawnLows) > 0
                        for k = 0 to array.size(drawnLows) - 1
                            if math.abs(mid - array.get(drawnLows, k)) <= tolerance
                                alreadyDrawn := true
                                break
                    if not alreadyDrawn
                        box.new(bar_index[j], mid + tolerance, bar_index, mid - tolerance,
                            border_color=color.new(color.blue, 0),
                            bgcolor=cEqLows,
                            text="EqLows",
                            text_color=color.white,
                            text_size=size.tiny)
                        array.push(drawnLows, mid)
                        poolLowCount += 1
                    break

    // --- TREND LINES ---
    if showTrend
        float[] swingHighs = array.new_float(0)
        int[]   swingHighIdx = array.new_int(0)
        for i = 2 to lookback - 2
            if high[i] > high[i-1] and high[i] > high[i-2] and high[i] > high[i+1] and high[i] > high[i+2]
                array.push(swingHighs, high[i])
                array.push(swingHighIdx, i)

        float[] swingLows = array.new_float(0)
        int[]   swingLowIdx = array.new_int(0)
        for i = 2 to lookback - 2
            if low[i] < low[i-1] and low[i] < low[i-2] and low[i] < low[i+1] and low[i] < low[i+2]
                array.push(swingLows, low[i])
                array.push(swingLowIdx, i)

        if array.size(swingHighs) >= 2
            p1 = array.get(swingHighs, array.size(swingHighs) - 2)
            p2 = array.get(swingHighs, array.size(swingHighs) - 1)
            i1 = array.get(swingHighIdx, array.size(swingHighIdx) - 2)
            i2 = array.get(swingHighIdx, array.size(swingHighIdx) - 1)
            if p2 < p1
                slope = (p2 - p1) / (i2 - i1)
                proj  = p2 + slope * (0 - i2)
                line.new(bar_index[i1], p1, bar_index, proj, color=cResistanceLine, style=line.style_dashed, width=2)
                if close > proj
                    label.new(bar_index, high, "Resistance Break", color=color.green, textcolor=color.white, style=label.style_label_down, size=size.small)

        if array.size(swingLows) >= 2
            p1 = array.get(swingLows, array.size(swingLows) - 2)
            p2 = array.get(swingLows, array.size(swingLows) - 1)
            i1 = array.get(swingLowIdx, array.size(swingLowIdx) - 2)
            i2 = array.get(swingLowIdx, array.size(swingLowIdx) - 1)
            if p2 > p1
                slope = (p2 - p1) / (i2 - i1)
                proj  = p2 + slope * (0 - i2)
                line.new(bar_index[i1], p1, bar_index, proj, color=cSupportLine, style=line.style_dashed, width=2)
                if close < proj
                    label.new(bar_index, low, "Support Break", color=color.red, textcolor=color.white, style=label.style_label_up, size=size.small)

    // --- OTE LABELS ---
    if showOTE and rangeSize > 0
        label.new(bar_index, oteLong,  "OTE Buy",  color=cOTE, textcolor=color.white, style=label.style_label_up,   size=size.tiny)
        label.new(bar_index, oteShort, "OTE Sell", color=cOTE, textcolor=color.white, style=label.style_label_down, size=size.tiny)

// --- INFO PANEL ---
var table infoPanel = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(infoPanel, 0, 0, "Liquidity Zones", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, "Active", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 0, 1, "Bullish OBs", text_color=color.teal, text_size=size.tiny)
    table.cell(infoPanel, 1, 1, "Auto", text_color=color.teal, text_size=size.tiny)
    table.cell(infoPanel, 0, 2, "Bearish OBs", text_color=color.maroon, text_size=size.tiny)
    table.cell(infoPanel, 1, 2, "Auto", text_color=color.maroon, text_size=size.tiny)
    table.cell(infoPanel, 0, 3, "FVGs", text_color=color.purple, text_size=size.tiny)
    table.cell(infoPanel, 1, 3, "Auto", text_color=color.purple, text_size=size.tiny)
    table.cell(infoPanel, 0, 4, "Trend", text_color=color.orange, text_size=size.tiny)
    table.cell(infoPanel, 1, 4, showTrend ? "ON" : "OFF", text_color=color.orange, text_size=size.tiny)
    table.cell(infoPanel, 0, 5, "Price", text_color=color.white, text_size=size.tiny)
    table.cell(infoPanel, 1, 5, str.tostring(close, format.mintick), text_color=color.white, text_size=size.tiny)

// ============================================================
// END OF INDICATOR
// ============================================================

# Copy this file to .env and fill in your values
# VcaniTrade Configuration

# --- LLM / BRAIN SETTINGS ---
# Ollama (local brain) - set to local Ollama URL
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_V1_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_K_M
MICRO_BRAIN_ENABLED=true
MICRO_BRAIN_MODEL=qwen2.5:1.5b-instruct-q4_K_M

# Account Balance (MUST match your prop firm or broker account)
CURRENT_BALANCE=50000.00

# Trading Safety Controls
# PRODUCTION: Keep DRY_RUN=True until you are ready to trade live capital.
DRY_RUN=True
MAX_DAILY_LOSS=100.00
MAX_OPEN_POSITIONS=3
COOLDOWN_AFTER_STOP=300

# Trading Mode (TEACHER or AUTO)
TEACHER_MODE=True

# Execution Surface
# TV_DESKTOP uses TradingView Desktop/Chrome CDP on port 9222.
# MT5 sends orders directly through MetaTrader 5.
EXECUTION_MODE=TV_DESKTOP
TRADING_SURFACE=TRADINGVIEW_DESKTOP
BROWSER_CDP_URL=http://127.0.0.1:9222
TV_DESKTOP_CDP_URL=http://127.0.0.1:9222

# Low-latency upgrades
LOW_LATENCY_EXECUTION_ENABLED=true
HYBRID_GATEWAY_PRIMARY=broker_ws
# Optional direct broker WebSocket. Leave blank until your broker endpoint/token are ready.
BROKER_WS_URL=
BROKER_WS_TOKEN=
BROKER_WS_TIMEOUT_SECONDS=0.75
BROKER_WS_DRY_RUN=true
FAST_VISION_ENABLED=true
FAST_VISION_BACKEND=auto
HUD_GLASS_ENABLED=true

# OpenRouter (cloud brain) - set if using cloud LLM
# External Brain API Keys (replace with your actual keys)
# Budget-friendly order: list free/low-cost keys FIRST, separated by commas.
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Which brain to use: "local" or "openrouter"
DEFAULT_BRAIN=local

# --- EXECUTION SETTINGS ---
# Trading desktop with R|Trader Pro (where execution_server.py must run)
EXECUTION_HOST=192.168.0.39
# Trading surface: RTRADER, WEALTHCHARTS, MT5
TRADING_SURFACE=RTRADER
EXECUTION_MODE=UI
# R|Trader Pro window hints (don't change unless your window title is different)
RTRADER_WINDOW_HINTS=R|Trader Pro,R|Trader,RTrader Pro,RTrader

# --- MULTI-MONITOR SETTINGS ---
MULTI_MONITOR_ENABLED=True
PRIMARY_MONITOR_WIDTH=1920
PRIMARY_MONITOR_HEIGHT=1080

# --- R|TRADER BUTTON COORDINATES ---
# Run coordinate_calibration.py on 192.168.0.39 to get these values
RTRADER_BUY_X=960
RTRADER_BUY_Y=540
RTRADER_SELL_X=960
RTRADER_SELL_Y=580
RTRADER_FLATTEN_X=960
RTRADER_FLATTEN_Y=620

# --- SAFETY SETTINGS ---
DRY_RUN=False
MAX_DAILY_LOSS=1000
DAILY_LOSS_LIMIT=3000
MAX_TRADES_PER_DAY=10

# --- PROP FIRM SETTINGS ---
PROP_FIRM_ENABLED=True
PROP_FIRM_NAME=TopStep
PROP_ACCOUNT_SIZE=50000
CURRENT_BALANCE=50000

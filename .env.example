# Copy this file to .env and fill in your values.
# VcanTrade AI - Apex Trader Funding edition
# ---------------------------------------------------------------------------
# Two execution surfaces, one switch (config.ACTIVE_EXECUTION_SURFACE):
#   * TRADINGVIEW  -> TradingView Desktop CDP / GhostExecutor JS click
#   * MT5          -> Native MetaTrader 5 order_send
# Flip the switch from the dashboard. The .env value is the boot default.
# ---------------------------------------------------------------------------

# ===== EXECUTION SURFACE (boot default; runtime switch lives on dashboard) =====
# TRADINGVIEW for the laptop/PC running TradingView Desktop on port 9222.
# MT5 for the MetaTrader 5 machine.
ACTIVE_EXECUTION_SURFACE=TRADINGVIEW
EXECUTION_MODE=UI
TRADING_SURFACE=TRADINGVIEW_DESKTOP

# ===== TRADINGVIEW DESKTOP =====
BROWSER_CDP_URL=http://127.0.0.1:9222
TV_DESKTOP_CDP_URL=http://127.0.0.1:9222
TRADINGVIEW_ACCOUNT_LABEL=Paper Trading

# ===== METATRADER 5 =====
# Default volume only used when the risk model produces no quantity.
MT5_VOLUME=0.1
MT5_REQUIRE_PROTECTIVE_STOP=true

# ===== SAFETY (ALWAYS ON BY DEFAULT) =====
# DRY_RUN must be False to send live orders. Single source of truth.
DRY_RUN=True
TEACHER_MODE=False
KILL_SWITCH=False

# Teacher-only lock: when true, the Autonomous button on the dashboard is
# disabled. The bot will analyze and suggest, but never click on its own.
# Set to true for installs where the human always approves every trade.
TEACHER_ONLY_LOCK=False

# ===== ACCOUNT =====
CURRENT_BALANCE=50000.00
HARDCODED_EQUITY_FALLBACK=50000.00

# ===== APEX TRADER FUNDING =====
PROP_FIRM_ENABLED=True
PROP_FIRM_NAME=Apex Trader Funding
PROP_ACCOUNT_SIZE=50000
PROP_PHASE=1
PROP_IS_FUNDED=False

# ===== UNIFIED DAILY LIMITS (one source of truth) =====
# Apex has no daily loss limit; the trailing drawdown is the active guard.
# Set MAX_DAILY_LOSS to 0 to disable, or to a dollar amount to enforce.
MAX_DAILY_LOSS=0
MAX_TRADES_PER_DAY=20
MAX_OPEN_POSITIONS=3
COOLDOWN_AFTER_STOP=300

# ===== TRADING HOURS (UTC). -1 disables the time gate. =====
TRADING_START_HOUR_UTC=12
TRADING_END_HOUR_UTC=21

# ===== LOCAL BRAIN (Ollama + Predator) =====
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_V1_URL=http://127.0.0.1:11434
OLLAMA_MODEL=predator:latest
MICRO_BRAIN_ENABLED=true
MICRO_BRAIN_MODEL=predator:latest
DEFAULT_BRAIN=local
LLM_TIMEOUT=180

# ===== VISION =====
USE_VISION=true
VLM_MODEL=llava:7b
VISION_TIMEOUT=120

# ===== SIGNAL LISTENER =====
LOCAL_LISTENER_HOST=0.0.0.0
LOCAL_LISTENER_HEALTH_HOST=127.0.0.1
LOCAL_LISTENER_PORT=17199

# ===== NEWS FILTER =====
# In AUTONOMOUS mode the news scraper now FAILS CLOSED (pauses trading) when
# Forex Factory is unreachable. Set this to "true" to override and keep
# trading even when the news feed is dark — only do that if you accept the
# risk of trading through NFP / FOMC.
NEWS_FILTER_FAIL_OPEN=false

# ===== LATENCY =====
LOW_LATENCY_EXECUTION_ENABLED=true
FAST_VISION_ENABLED=true
FAST_VISION_BACKEND=auto
HUD_GLASS_ENABLED=true

# Skip the "Lion Switchboard" startup dialog. The launcher already picks the
# correct surface, so the dialog is just an extra click. Set to true if you
# want the chooser back.
SHOW_STARTUP_SWITCHBOARD=false

# ===== OPTIONAL CLOUD BRAIN (leave blank for fully local) =====
GEMINI_ENABLED=False
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEYS=
NVIDIA_API_KEY=
BRAINSTORM_API_KEY=
GOOGLE_API_KEY=

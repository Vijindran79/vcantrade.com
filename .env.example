# VcaniTrade AI - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Account Balance (MUST match your prop firm or broker account)
CURRENT_BALANCE=50000.00

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Trading Safety Controls
# PRODUCTION: Keep DRY_RUN=True until you are ready to trade live capital.
DRY_RUN=True
MAX_DAILY_LOSS=100.00
MAX_OPEN_POSITIONS=3
COOLDOWN_AFTER_STOP=300

# Trading Mode (TEACHER or AUTO)
TEACHER_MODE=True

# External Brain API Keys (replace with your actual keys)
# Budget-friendly order: list free/low-cost keys FIRST, separated by commas.
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEYS=
NVIDIA_API_KEY=
BRAINSTORM_API_KEY=

# Google API Key (reserved slot - stays empty for now)
GOOGLE_API_KEY=

# RPA Fallback Coordinates (update to match your screen layout)
FALLBACK_BUY_X=960
FALLBACK_BUY_Y=540
FALLBACK_SELL_X=960
FALLBACK_SELL_Y=580

# UI Settings
OVERLAY_ALPHA=0.15
OVERLAY_UPDATE_MS=2000
SHOW_REASONING=True

# Logging
LOG_LEVEL=INFO
